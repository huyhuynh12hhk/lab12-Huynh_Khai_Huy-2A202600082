# ============================================================
# .env.example — copy to .env.local and fill in your values
# This file is safe to commit; .env.local is gitignored.
# ============================================================

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development   # development | staging | production
DEBUG=false

# ── App ─────────────────────────────────────────────────────
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# ── Security ─────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_KEY=dev-key-change-me

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ── Budget guard ─────────────────────────────────────────────
MONTHLY_BUDGET_USD=10.0

# ── Redis ────────────────────────────────────────────────────
# Local:   redis://localhost:6379/0
# Docker:  redis://redis:6379/0
# Railway: provided automatically via $REDIS_URL
REDIS_URL=redis://localhost:6379/0

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
